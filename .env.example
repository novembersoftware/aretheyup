ENV=dev # optional, defaults to dev -- can be prod
API_PORT=8080 # optional, defaults to 8080

# from docker-compose.dev.yml
DB_DSN=postgres://aretheyup:aretheyup@localhost:5432/aretheyup 
REDIS_URL=redis://localhost:6379
SITE_BASE_URL=https://aretheyup.com
ALLOWED_PAGE_ORIGINS=https://aretheyup.com,https://www.aretheyup.com
# Comma-separated CIDRs/IPs for reverse proxies allowed to provide X-Forwarded-For.
# Keep empty to trust none.
TRUSTED_PROXIES=

# rate limits
REPORT_RATE_LIMIT_MAX_REQUESTS=1
REPORT_RATE_LIMIT_WINDOW_SECONDS=1800
